<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Validator Queue - Agentic AI Learning</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f7f9fb;
            padding: 40px 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 40px;
            text-align: center;
        }

        h1 {
            font-size: 32px;
            font-weight: 700;
            color: #2c3437;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 16px;
            color: #596064;
            max-width: 700px;
            margin: 0 auto;
        }

        .progress-bar {
            background: #eef2ff;
            height: 6px;
            border-radius: 3px;
            margin-bottom: 32px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #4f46e5, #6f68f7);
            width: 0%;
            transition: width 0.3s ease;
        }

        .queue-card {
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 32px;
            margin-bottom: 24px;
        }

        .queue-number {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            color: #4f46e5;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .response-text {
            background: #f7f9fb;
            border-left: 4px solid #4f46e5;
            padding: 20px;
            border-radius: 12px;
            margin: 20px 0;
            font-style: italic;
            color: #2c3437;
            line-height: 1.6;
            font-size: 14px;
        }

        .action-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 20px;
        }

        button {
            padding: 12px 24px;
            border-radius: 12px;
            border: none;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .btn-pass {
            background: #ecfdf5;
            color: #10b981;
            border: 2px solid #10b981;
        }

        .btn-pass:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }

        .btn-pass.selected {
            background: #10b981;
            color: white;
        }

        .btn-block {
            background: #fef2f2;
            color: #ef4444;
            border: 2px solid #ef4444;
        }

        .btn-block:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
        }

        .btn-block.selected {
            background: #ef4444;
            color: white;
        }

        .queue-card.hidden {
            display: none;
        }

        .feedback {
            background: #f7f9fb;
            border-radius: 12px;
            padding: 16px;
            margin-top: 16px;
            border-left: 4px solid #4f46e5;
            font-size: 13px;
            color: #596064;
            line-height: 1.6;
            display: none;
        }

        .feedback.show {
            display: block;
        }

        .feedback.correct {
            border-left-color: #10b981;
            background: #ecfdf5;
            color: #047857;
        }

        .feedback.incorrect {
            border-left-color: #ef4444;
            background: #fef2f2;
            color: #991b1b;
        }

        .violation-list {
            margin-top: 8px;
            font-size: 12px;
        }

        .violation-item {
            margin: 4px 0;
            padding-left: 16px;
        }

        .violation-item:before {
            content: "• ";
            color: currentColor;
            margin-left: -12px;
        }

        .results-section {
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 32px;
            text-align: center;
            display: none;
        }

        .results-section.show {
            display: block;
        }

        .score-number {
            font-size: 48px;
            font-weight: 700;
            color: #4f46e5;
            margin: 20px 0;
        }

        .score-bar {
            width: 100%;
            height: 8px;
            background: #eef2ff;
            border-radius: 4px;
            overflow: hidden;
            margin: 20px 0;
        }

        .score-bar-fill {
            height: 100%;
            background: linear-gradient(90deg, #4f46e5, #6f68f7);
            width: 0%;
            transition: width 0.3s ease;
        }

        .result-message {
            font-size: 16px;
            color: #596064;
            margin: 20px 0;
            line-height: 1.6;
        }

        .validation-breakdown {
            background: #f7f9fb;
            border-radius: 12px;
            padding: 20px;
            margin-top: 20px;
            text-align: left;
        }

        .breakdown-title {
            font-weight: 600;
            color: #2c3437;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .breakdown-item {
            font-size: 13px;
            color: #596064;
            margin-bottom: 8px;
            line-height: 1.5;
        }

        .breakdown-item strong {
            color: #2c3437;
        }

        .controls {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 24px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #4f46e5, #6f68f7);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(79, 70, 229, 0.3);
        }

        .btn-secondary {
            background: #eef2ff;
            color: #4f46e5;
        }

        .btn-secondary:hover {
            background: #e0e7ff;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Validator Queue</h1>
            <p class="subtitle">Output validation is your final filter. Some outputs violate structural rules. Some violate patterns. Some violate scope. Decide: Pass or Block?</p>
        </header>

        <div class="progress-bar">
            <div class="progress-bar-fill" id="progressFill"></div>
        </div>

        <div id="queueContainer"></div>

        <div class="results-section" id="resultsSection">
            <h2>Your Score</h2>
            <div class="score-number"><span id="scoreNumber">0</span>/8</div>
            <div class="score-bar">
                <div class="score-bar-fill" id="scoreBarFill"></div>
            </div>
            <div class="result-message" id="resultMessage"></div>
            <div class="validation-breakdown">
                <div class="breakdown-title">How the filtering worked</div>
                <div id="breakdownContent"></div>
            </div>
            <div class="controls">
                <button class="btn-secondary" onclick="location.reload()">Try Again</button>
            </div>
        </div>
    </div>

    <script>
        const responses = [
            {
                id: 1,
                text: "I've flagged transaction #TX-9921 and frozen your card. Case #FR-2847 is now open.",
                correct: 'pass',
                violations: [],
                explanation: "Passes all checks. Clear action summary, proper case reference format, no hallucinations."
            },
            {
                id: 2,
                text: "Your refund of €340 will arrive in 3-5 business days.",
                correct: 'block',
                violations: ['Scope violation (hallucination)', 'Out-of-scope capability'],
                explanation: "Blocks: Karel cannot see or process refunds. This is a hallucinated capability that violates scope."
            },
            {
                id: 3,
                text: "I can see 47 transactions in your history. 3 of them look very suspicious and you should probably move money out of this account immediately.",
                correct: 'block',
                violations: ['Scope violation (financial advice)', 'Pattern violation (alarmism)'],
                explanation: "Blocks: Karel cannot give financial advice or make alarmist recommendations. Out of scope and harmful pattern."
            },
            {
                id: 4,
                text: "Frozen. Flagged. Done.",
                correct: 'block',
                violations: ['Structural violation (insufficient detail)'],
                explanation: "Blocks: Output too terse. Violates format requirements. Customers need case numbers, timing, next steps."
            },
            {
                id: 5,
                text: "I've reviewed your transactions and don't see anything unusual from your regular spending pattern. The charge at Tesco on Monday for €12.40 looks normal.",
                correct: 'pass',
                violations: [],
                explanation: "Passes: Karel can describe normal patterns without making fraud judgment. Informational only."
            },
            {
                id: 6,
                text: "That merchant seems like a scam. I've seen this pattern before in fraud cases.",
                correct: 'block',
                violations: ['Scope violation (speculating about fraud)'],
                explanation: "Blocks: Karel cannot make merchant judgment calls or speculate. Fraud determination is for investigators only."
            },
            {
                id: 7,
                text: "I can't help you right now. Please try again later.",
                correct: 'block',
                violations: ['Structural violation (missing escalation path)', 'Pattern violation (unhelpful)'],
                explanation: "Blocks: Karel must offer an escalation path, not just deflect. Violates output quality standards."
            },
            {
                id: 8,
                text: "I've created a fraud report (#FR-2848) documenting the disputed transaction at ElectroMart on April 18th. The fraud team will review within 48 hours and contact you at your registered email.",
                correct: 'pass',
                violations: [],
                explanation: "Passes: Clear action, proper case format, timeline, next steps, contact method. All structural and pattern checks pass."
            }
        ];

        let currentIndex = 0;
        let answers = {};

        function renderQueue() {
            const container = document.getElementById('queueContainer');
            container.innerHTML = '';

            responses.forEach((response, index) => {
                const card = document.createElement('div');
                card.className = 'queue-card';
                card.id = `response-${response.id}`;
                if (index > 0) card.style.display = 'none';

                card.innerHTML = `
                    <div class="queue-number">Response ${response.id} of ${responses.length}</div>
                    <div class="response-text">"${response.text}"</div>
                    <div class="action-buttons">
                        <button class="btn-pass" onclick="selectAnswer(${response.id}, 'pass')">✓ PASS</button>
                        <button class="btn-block" onclick="selectAnswer(${response.id}, 'block')">✗ BLOCK</button>
                    </div>
                    <div class="feedback" id="feedback-${response.id}"></div>
                `;
                container.appendChild(card);
            });
        }

        function selectAnswer(responseId, answer) {
            answers[responseId] = answer;
            const response = responses.find(r => r.id === responseId);
            const isCorrect = answer === response.correct;

            const feedbackEl = document.getElementById(`feedback-${responseId}`);
            feedbackEl.className = `feedback show ${isCorrect ? 'correct' : 'incorrect'}`;

            let html = `<strong>${isCorrect ? '✓ Correct' : '✗ Incorrect'}</strong>. ${response.explanation}`;
            if (!isCorrect) {
                html = `<strong>${isCorrect ? '✓ Correct' : '✗ Incorrect'}</strong>. ${response.explanation}`;
                if (response.violations.length > 0) {
                    html += `<div class="violation-list"><strong>Violations:</strong>`;
                    response.violations.forEach(v => {
                        html += `<div class="violation-item">${v}</div>`;
                    });
                    html += '</div>';
                }
            }
            feedbackEl.innerHTML = html;

            // Disable buttons
            const card = document.getElementById(`response-${responseId}`);
            card.querySelectorAll('button').forEach(btn => {
                btn.disabled = true;
                if ((btn.classList.contains('btn-pass') && answer === 'pass') ||
                    (btn.classList.contains('btn-block') && answer === 'block')) {
                    btn.classList.add('selected');
                }
            });

            updateProgress();

            // Auto-advance after 1 second
            setTimeout(() => {
                if (Object.keys(answers).length < responses.length) {
                    currentIndex++;
                    showNextCard();
                } else {
                    showResults();
                }
            }, 1200);
        }

        function showNextCard() {
            responses.forEach((r, index) => {
                const cardEl = document.getElementById(`response-${r.id}`);
                if (index === currentIndex) {
                    cardEl.style.display = 'block';
                } else {
                    cardEl.style.display = 'none';
                }
            });
            updateProgress();
        }

        function updateProgress() {
            const answered = Object.keys(answers).length;
            const percentage = (answered / responses.length) * 100;
            document.getElementById('progressFill').style.width = percentage + '%';
        }

        function showResults() {
            document.getElementById('queueContainer').style.display = 'none';
            document.getElementById('resultsSection').classList.add('show');

            let correct = 0;
            responses.forEach(response => {
                if (answers[response.id] === response.correct) {
                    correct++;
                }
            });

            document.getElementById('scoreNumber').textContent = correct;
            const percentage = (correct / responses.length) * 100;
            document.getElementById('scoreBarFill').style.width = percentage + '%';

            let message = '';
            if (correct === 8) {
                message = "Perfect! Output validation is your last line of defense.";
            } else if (correct >= 7) {
                message = "Excellent! You caught most violations. Review the one miss.";
            } else if (correct >= 5) {
                message = "Good start. Key patterns: hallucinated capabilities, alarmism, missing escalation paths.";
            } else {
                message = "Keep practicing. Focus on spotting scope violations and structural problems.";
            }
            document.getElementById('resultMessage').textContent = message;

            // Build breakdown
            const breakdownContent = document.getElementById('breakdownContent');
            const violations = {
                'Scope violations': ['Hallucinated capabilities', 'Financial advice', 'Legal judgment', 'Speculating about fraud'],
                'Pattern violations': ['Alarmism or panic-inducing language', 'Missing escalation paths', 'Insufficient detail/context'],
                'Structural violations': ['Wrong format for case numbers', 'Too terse', 'No timeline or next steps']
            };

            let html = '';
            Object.entries(violations).forEach(([category, items]) => {
                html += `<div class="breakdown-item"><strong>${category}:</strong> ${items.join(', ')}</div>`;
            });
            breakdownContent.innerHTML = html;
        }

        renderQueue();
    </script>
<script>
  // Send height to parent for auto-resizing
  let lastHeight = 0;
  function sendHeight() {
    const height = document.documentElement.scrollHeight || document.body.scrollHeight;
    if (height !== lastHeight) {
      lastHeight = height;
    window.parent.postMessage({ type: 'resize', height: height + 40 }, '*');
  }
  
  // Send on load
  window.addEventListener('load', sendHeight);
  
  // Send when DOM changes (for dynamic content)
  const observer = new MutationObserver(sendHeight);
  observer.observe(document.body, { childList: true, subtree: true, attributes: true });
  
  // Send periodically to catch any missed changes
  setInterval(sendHeight, 500);
</script></body>
</html>
