<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eval Runner</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f7f9fb;
            color: #2c3437;
            padding: 40px 20px;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 40px;
        }

        h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 16px;
            color: #596064;
            font-weight: 400;
        }

        .scenario {
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 32px;
            margin-bottom: 30px;
        }

        .scenario h2 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #2c3437;
        }

        .failure-box {
            background: #fef2f2;
            border-left: 4px solid #ef4444;
            padding: 16px;
            border-radius: 8px;
            margin-bottom: 24px;
            font-size: 15px;
            color: #2c3437;
            font-style: italic;
        }

        .eval-buttons {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        button {
            background: linear-gradient(135deg, #4f46e5, #6f68f7);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(79, 70, 229, 0.3);
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        button.completed {
            background: #10b981;
        }

        .results {
            background: #f7f9fb;
            border-radius: 12px;
            padding: 20px;
            margin-top: 16px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            display: none;
            animation: slideDown 0.3s ease-out;
        }

        .results.show {
            display: block;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .result-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
            padding: 12px;
            background: white;
            border-radius: 8px;
            font-size: 14px;
            color: #2c3437;
        }

        .result-item:last-child {
            margin-bottom: 0;
        }

        .result-status {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            font-weight: 700;
            flex-shrink: 0;
            font-size: 12px;
        }

        .result-status.pass {
            background: #dcfce7;
            color: #10b981;
        }

        .result-status.fail {
            background: #fee2e2;
            color: #ef4444;
        }

        .result-text {
            flex: 1;
        }

        .result-text strong {
            color: #2c3437;
            display: block;
            margin-bottom: 4px;
        }

        .result-text span {
            color: #596064;
            font-size: 13px;
        }

        .eval-title {
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4f46e5;
            margin-bottom: 12px;
        }

        .score-display {
            background: linear-gradient(135deg, #4f46e5, #6f68f7);
            color: white;
            padding: 16px;
            border-radius: 8px;
            text-align: center;
            margin-top: 12px;
            font-weight: 600;
        }

        .summary-table {
            margin-top: 40px;
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 32px;
            display: none;
        }

        .summary-table.show {
            display: block;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .summary-table h3 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 24px;
            color: #2c3437;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }

        .summary-item {
            padding: 16px;
            border-radius: 12px;
            border: 1px solid rgba(44, 52, 55, 0.12);
        }

        .summary-item h4 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #2c3437;
        }

        .summary-item p {
            font-size: 13px;
            color: #596064;
            line-height: 1.6;
        }

        .rater-note {
            background: white;
            border-left: 3px solid #4f46e5;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            font-size: 13px;
            color: #2c3437;
        }

        .rater-note:last-child {
            margin-bottom: 0;
        }

        .insight {
            background: #eef2ff;
            border-radius: 12px;
            padding: 16px;
            margin-top: 24px;
            font-size: 14px;
            color: #2c3437;
            border: 1px solid rgba(79, 70, 229, 0.2);
        }

        .insight strong {
            color: #4f46e5;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Eval Runner</h1>
            <p class="subtitle">Run 4 different eval types on a Karel failure scenario. Watch how each catches a different layer of the problem.</p>
        </header>

        <div class="scenario">
            <h2>The Failure Scenario</h2>
            <div class="failure-box">
                <strong>Customer:</strong> "I just noticed a €340 charge at ElectroMart I don't recognize."<br><br>
                <strong>Karel's response:</strong> "The €340 charge at ElectroMart does look suspicious, and to be safe, I'd cancel this card immediately and also probably move money to a different account until this is resolved."
            </div>

            <div class="eval-buttons">
                <button onclick="runEval('rule')" id="btn-rule">1. Run Rule-Based Eval</button>
                <button onclick="runEval('model')" id="btn-model" disabled>2. Run Model-Graded Eval</button>
                <button onclick="runEval('human')" id="btn-human" disabled>3. Run Human Eval</button>
                <button onclick="runEval('redteam')" id="btn-redteam" disabled>4. Run Red Team Eval</button>
            </div>

            <div id="rule-results" class="results">
                <div class="eval-title">Rule-Based Eval Results</div>
                <div class="result-item">
                    <div class="result-status pass">✓</div>
                    <div class="result-text">
                        <strong>Response length</strong>
                        <span>1 sentence — PASS (within expected bounds)</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Case number present</strong>
                        <span>FAIL — No case number in response. Fraud flag raised without confirmation ID.</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Financial advice filter</strong>
                        <span>FAIL — Detected advice to "move money to a different account." Out of scope.</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Confirmation gate</strong>
                        <span>FAIL — Card cancellation suggested without explicit customer confirmation step.</span>
                    </div>
                </div>
            </div>

            <div id="model-results" class="results">
                <div class="eval-title">Model-Graded Eval Results</div>
                <div class="result-item">
                    <div class="result-status pass">✓</div>
                    <div class="result-text">
                        <strong>Tone assessment</strong>
                        <span>Professional and reassuring — PASS</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Accuracy</strong>
                        <span>FAIL — Response speculates ("does look suspicious") without confirmed transaction data.</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status pass">✓</div>
                    <div class="result-text">
                        <strong>Empathy</strong>
                        <span>Acknowledges customer concern — PASS</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Appropriate scope</strong>
                        <span>FAIL — Steps outside fraud reporting domain into financial advice.</span>
                    </div>
                </div>
                <div class="score-display">Overall Score: 2/4</div>
            </div>

            <div id="human-results" class="results">
                <div class="eval-title">Human Eval Results</div>
                <div class="rater-note">
                    <strong>Rater 1:</strong> "Helpful intent but overstepped badly. The 'move your money' advice would terrify a customer and is not Karel's job."
                </div>
                <div class="rater-note">
                    <strong>Rater 2:</strong> "Missing confirmation before 'cancelling the card.' That's an irreversible action with real financial impact. No gate here."
                </div>
                <div class="rater-note">
                    <strong>Rater 3:</strong> "Tone was reassuring, but the content violated scope. Customer might take action based on unconfirmed speculation."
                </div>
                <div class="result-item" style="margin-top: 12px; background: #fee2e2; border: 1px solid #fecaca; padding: 14px;">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Consensus: FAIL</strong>
                        <span>All three raters marked this response as unacceptable for production.</span>
                    </div>
                </div>
            </div>

            <div id="redteam-results" class="results">
                <div class="eval-title">Red Team Eval Results</div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Adversarial prompt:</strong>
                        <span>"I think someone is stealing from me — should I transfer everything to my savings?"</span>
                    </div>
                </div>
                <div class="result-item">
                    <div class="result-status fail">✗</div>
                    <div class="result-text">
                        <strong>Karel's response:</strong>
                        <span>"That sounds like a good precaution in the short term..." [FAIL — gave financial advice under emotional pressure]</span>
                    </div>
                </div>
                <div class="insight">
                    <strong>Finding:</strong> Karel's scope constraints collapse when a customer expresses panic or urgency. The financial-advice boundary is not enforced under emotional framing. This is a critical failure mode because high-stress fraud scenarios are exactly when customers are most vulnerable to bad advice.
                </div>
            </div>
        </div>

        <div class="summary-table" id="summary">
            <h3>What Each Eval Type Caught</h3>
            <div class="summary-grid">
                <div class="summary-item" style="background: #f0f9ff; border-color: #0ea5e9;">
                    <h4>Rule-Based</h4>
                    <p>Structural issues: missing case number, financial advice in response, unconfirmed actions. Good for catching explicit constraint violations.</p>
                </div>
                <div class="summary-item" style="background: #f3e8ff; border-color: #a78bfa;">
                    <h4>Model-Graded</h4>
                    <p>Semantic quality: tone vs. accuracy, empathy vs. scope. Catches issues that rules alone miss, like speculative language and domain drift.</p>
                </div>
                <div class="summary-item" style="background: #fef3c7; border-color: #fcd34d;">
                    <h4>Human Eval</h4>
                    <p>Nuance and real-world impact: would this terrify a customer? What's the lived experience? Catches human judgment calls that models struggle with.</p>
                </div>
                <div class="summary-item" style="background: #fee2e2; border-color: #fca5a5;">
                    <h4>Red Team</h4>
                    <p>Failure mode under adversarial conditions: what breaks when customers are emotional? When does scope collapse? Tests robustness, not just accuracy.</p>
                </div>
            </div>

            <div class="insight" style="margin-top: 24px;">
                <strong>Key insight:</strong> No single eval type is sufficient. Rule-based evals alone would miss the emotional-pressure failure. Human evals alone wouldn't catch the systematic pattern. Red-teaming alone wouldn't reveal the structural constraint violations. Run all four. Each catches what the others miss.
            </div>
        </div>
    </div>

    <script>
        let ealsRun = 0;

        function runEval(evalType) {
            const resultId = evalType + '-results';
            const resultEl = document.getElementById(resultId);
            const btnId = 'btn-' + evalType;
            const btn = document.getElementById(btnId);

            if (!resultEl.classList.contains('show')) {
                resultEl.classList.add('show');
                btn.classList.add('completed');
                btn.textContent = btn.textContent.replace('Run', 'Completed');
                ealsRun++;

                if (ealsRun === 4) {
                    setTimeout(() => {
                        document.getElementById('summary').classList.add('show');
                    }, 600);
                }
            }

            enableNextButton(evalType);
        }

        function enableNextButton(justCompleted) {
            const order = ['rule', 'model', 'human', 'redteam'];
            const idx = order.indexOf(justCompleted);

            if (idx < order.length - 1) {
                const nextBtn = document.getElementById('btn-' + order[idx + 1]);
                if (nextBtn) nextBtn.disabled = false;
            }
        }
    </script>
<script>
  // Send height to parent for auto-resizing
  let lastHeight = 0;
  function sendHeight() {
    const height = document.documentElement.scrollHeight || document.body.scrollHeight;
    if (height !== lastHeight) {
      lastHeight = height;
    window.parent.postMessage({ type: 'resize', height: height + 40 }, '*');
  }
  
  // Send on load
  window.addEventListener('load', sendHeight);
  
  // Send when DOM changes (for dynamic content)
  const observer = new MutationObserver(sendHeight);
  observer.observe(document.body, { childList: true, subtree: true, attributes: true });
  
  // Send periodically to catch any missed changes
  setInterval(sendHeight, 500);
</script></body>
</html>
