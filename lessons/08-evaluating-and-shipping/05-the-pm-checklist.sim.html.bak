<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ship Decision</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f7f9fb;
            color: #2c3437;
            padding: 40px 20px;
            line-height: 1.6;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 40px;
        }

        h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 16px;
            color: #596064;
            font-weight: 400;
            margin-bottom: 24px;
        }

        .task-context {
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 32px;
            margin-bottom: 30px;
        }

        .task-context p {
            font-size: 15px;
            color: #596064;
            line-height: 1.8;
            margin-bottom: 16px;
        }

        .task-context p:last-child {
            margin-bottom: 0;
        }

        .highlight {
            background: #eef2ff;
            border-left: 4px solid #4f46e5;
            padding: 16px;
            border-radius: 8px;
            margin-top: 16px;
        }

        .checklist {
            display: flex;
            flex-direction: column;
            gap: 24px;
            margin-bottom: 30px;
        }

        .section {
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 28px;
            overflow: hidden;
        }

        .section.complete {
            border-color: #10b981;
        }

        .section.complete::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: #10b981;
        }

        .section.incomplete {
            border-color: #ef4444;
        }

        .section.incomplete::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: #ef4444;
        }

        .section h2 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 4px;
            color: #2c3437;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-indicator {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            font-weight: 700;
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .section.complete .section-indicator {
            background: #10b981;
            color: white;
        }

        .section.incomplete .section-indicator {
            background: #ef4444;
            color: white;
        }

        .section-subtitle {
            font-size: 13px;
            color: #596064;
            margin-bottom: 20px;
            font-weight: 400;
        }

        .questions {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .question {
            padding: 16px;
            background: #f7f9fb;
            border-radius: 12px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            cursor: pointer;
            transition: all 0.2s;
        }

        .question:hover {
            background: #eef2ff;
            border-color: #4f46e5;
        }

        .question-text {
            font-size: 14px;
            font-weight: 500;
            color: #2c3437;
            margin-bottom: 12px;
        }

        .question-options {
            display: flex;
            gap: 12px;
        }

        .q-btn {
            padding: 8px 14px;
            border-radius: 8px;
            border: 1px solid rgba(44, 52, 55, 0.2);
            background: white;
            color: #596064;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .q-btn:hover {
            border-color: #4f46e5;
            color: #4f46e5;
        }

        .q-btn.selected.yes {
            background: #dcfce7;
            border-color: #10b981;
            color: #10b981;
        }

        .q-btn.selected.no {
            background: #fee2e2;
            border-color: #ef4444;
            color: #ef4444;
        }

        .flag-note {
            background: #fee2e2;
            border-left: 3px solid #ef4444;
            padding: 12px;
            border-radius: 6px;
            font-size: 12px;
            color: #991b1b;
            margin-top: 8px;
            display: none;
        }

        .flag-note.show {
            display: block;
        }

        .verdict {
            background: white;
            border-radius: 24px;
            border: 1px solid rgba(44, 52, 55, 0.12);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            padding: 40px;
            text-align: center;
            display: none;
            animation: slideUp 0.4s ease-out;
        }

        .verdict.show {
            display: block;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .verdict-title {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 16px;
            color: #2c3437;
        }

        .verdict.ready .verdict-title {
            color: #10b981;
        }

        .verdict.notready .verdict-title {
            color: #ef4444;
        }

        .verdict-subtitle {
            font-size: 16px;
            color: #596064;
            margin-bottom: 32px;
        }

        .verdict-icon {
            font-size: 80px;
            margin-bottom: 20px;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 32px;
            text-align: left;
        }

        .red-flag {
            padding: 20px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 12px;
        }

        .red-flag h4 {
            font-size: 14px;
            font-weight: 600;
            color: #991b1b;
            margin-bottom: 8px;
        }

        .red-flag p {
            font-size: 13px;
            color: #7f1d1d;
            line-height: 1.6;
            margin-bottom: 8px;
        }

        .red-flag p:last-child {
            margin-bottom: 0;
        }

        .fix-item {
            display: flex;
            gap: 12px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid rgba(99, 29, 29, 0.2);
        }

        .fix-item strong {
            color: #991b1b;
            flex-shrink: 0;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .progress-summary {
            font-size: 12px;
            color: #596064;
            font-weight: 500;
        }

        .progress-bar-small {
            height: 4px;
            background: rgba(79, 70, 229, 0.1);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 8px;
        }

        .progress-fill-small {
            height: 100%;
            background: #4f46e5;
            transition: width 0.3s;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Ship Decision</h1>
            <p class="subtitle">You are a PM reviewing Karel before launch. The checklist has 6 sections. Every "no" answer means Karel isn't ready. Work through all sections, then make your go/no-go call.</p>
        </header>

        <div class="task-context">
            <p><strong>The Karel build you're evaluating:</strong> The team has been working on fraud-detection agent for 6 weeks. Engineering says it's "ready to ship." The CEO wants to launch next week. You have the PM checklist. Use it to figure out if that's actually safe.</p>
            <div class="highlight">
                <strong>Your job:</strong> Answer yes/no to each question. Count the red flags. Then decide: is Karel ready to ship, or does something need fixing first?
            </div>
        </div>

        <div class="checklist" id="checklist"></div>

        <div class="verdict" id="verdict"></div>
    </div>

    <script>
        const sections = [
            {
                name: 'Scope and Design',
                description: 'Are the boundaries clear and locked in?',
                questions: [
                    {
                        text: 'Is the scope explicitly documented?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Were legal and compliance involved in scope decisions?',
                        flagIfNo: true,
                        flagNote: 'Red flag: Skipped compliance review to meet deadline. This will cause problems post-launch.'
                    },
                    {
                        text: 'Do the tools match the intended scope and nothing more?',
                        flagIfNo: true,
                        flagNote: 'Red flag: process_refund tool still in toolkit from old prototype. Out of scope, untested, dangerous.'
                    }
                ]
            },
            {
                name: 'Prompt Engineering',
                description: 'Are hard constraints actually hard?',
                questions: [
                    {
                        text: 'Are hard constraints written with definitive language?',
                        flagIfNo: true,
                        flagNote: 'Red flag: Constraints use "try to avoid" and "should probably." Not strong enough. Karel will violate them under pressure.'
                    },
                    {
                        text: 'Does every constraint have an explicit alternative?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Has the full system prompt been reviewed for internal consistency?',
                        flagIfNo: true,
                        flagNote: 'Red flag: Prompt reviewed in sections by different people. No one has read the whole thing. Likely contains contradictions.'
                    }
                ]
            },
            {
                name: 'Evaluation',
                description: 'Have you proven it works?',
                questions: [
                    {
                        text: 'Do you have explicit pass/fail success criteria?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Does the eval set include adversarial cases?',
                        flagIfNo: true,
                        flagNote: 'Red flag: Evals only cover happy path and edge cases. No red-teaming. You have no idea how Karel fails under adversarial input.'
                    },
                    {
                        text: 'Does a system prompt change trigger an eval run?',
                        flagIfNo: false,
                        flagNote: ''
                    }
                ]
            },
            {
                name: 'Trust and Safety',
                description: 'Can this agent hurt someone?',
                questions: [
                    {
                        text: 'Is there a confirmation gate on every irreversible action?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Is every tool call logged?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Can you answer: what is the worst thing this agent could do?',
                        flagIfNo: false,
                        flagNote: ''
                    }
                ]
            },
            {
                name: 'Observability',
                description: 'Will you know if it breaks in production?',
                questions: [
                    {
                        text: 'Are all 5 key metrics being monitored from day one?',
                        flagIfNo: true,
                        flagNote: 'Red flag: Customer satisfaction survey not set up. You cannot measure if Karel is actually helping or hurting customer experience in production.'
                    },
                    {
                        text: 'Is there a defined response protocol for metric alerts?',
                        flagIfNo: false,
                        flagNote: ''
                    }
                ]
            },
            {
                name: 'Human Judgment',
                description: 'Does leadership understand what this agent will and won\'t do?',
                questions: [
                    {
                        text: 'Is there a clear escalation path?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Have you been honest about what the agent is not good at yet?',
                        flagIfNo: false,
                        flagNote: ''
                    },
                    {
                        text: 'Can you explain in plain language what this agent will and won\'t do?',
                        flagIfNo: false,
                        flagNote: ''
                    }
                ]
            }
        ];

        let answers = {};
        let redFlags = 0;

        const checklistDiv = document.getElementById('checklist');

        sections.forEach((section, sectionIdx) => {
            const sectionEl = document.createElement('div');
            sectionEl.className = 'section';
            sectionEl.dataset.section = sectionIdx;

            let sectionHTML = `
                <div class="section-header">
                    <div>
                        <h2>
                            <span class="section-indicator">?</span>
                            ${section.name}
                        </h2>
                        <div class="section-subtitle">${section.description}</div>
                    </div>
                    <div class="progress-summary"><span class="progress-text">0/${section.questions.length}</span></div>
                </div>
                <div class="questions">
            `;

            section.questions.forEach((q, qIdx) => {
                const questionId = `q-${sectionIdx}-${qIdx}`;
                sectionHTML += `
                    <div class="question">
                        <div class="question-text">${q.text}</div>
                        <div class="question-options">
                            <button class="q-btn" onclick="answerQuestion(${sectionIdx}, ${qIdx}, true)">Yes</button>
                            <button class="q-btn" onclick="answerQuestion(${sectionIdx}, ${qIdx}, false)">No</button>
                        </div>
                        <div class="flag-note">${q.flagNote}</div>
                    </div>
                `;
            });

            sectionHTML += '</div>';
            sectionEl.innerHTML = sectionHTML;
            checklistDiv.appendChild(sectionEl);

            answers[sectionIdx] = {};
        });

        function answerQuestion(sectionIdx, qIdx, answer) {
            const section = sections[sectionIdx];
            const question = section.questions[qIdx];
            const sectionEl = document.querySelector(`[data-section="${sectionIdx}"]`);
            const questionEl = sectionEl.querySelectorAll('.question')[qIdx];
            const yesBtn = questionEl.querySelector('.q-btn:first-child');
            const noBtn = questionEl.querySelector('.q-btn:last-child');
            const flagNote = questionEl.querySelector('.flag-note');

            // Remove previous selection
            yesBtn.classList.remove('selected');
            noBtn.classList.remove('selected');
            flagNote.classList.remove('show');

            // Add new selection
            if (answer) {
                yesBtn.classList.add('selected', 'yes');
            } else {
                noBtn.classList.add('selected', 'no');
                if (question.flagIfNo) {
                    flagNote.classList.add('show');
                }
            }

            answers[sectionIdx][qIdx] = answer;

            // Check if all questions in section are answered
            let sectionComplete = true;
            let sectionFails = 0;
            for (let i = 0; i < section.questions.length; i++) {
                if (!(i in answers[sectionIdx])) {
                    sectionComplete = false;
                } else if (!answers[sectionIdx][i] && section.questions[i].flagIfNo) {
                    sectionFails++;
                }
            }

            // Update section status
            const answeredCount = Object.keys(answers[sectionIdx]).length;
            sectionEl.querySelector('.progress-text').textContent = `${answeredCount}/${section.questions.length}`;

            if (sectionComplete) {
                sectionEl.classList.add(sectionFails > 0 ? 'incomplete' : 'complete');
                sectionEl.classList.remove(sectionFails > 0 ? 'complete' : 'incomplete');
                const indicator = sectionEl.querySelector('.section-indicator');
                indicator.textContent = sectionFails > 0 ? '✗' : '✓';
            }

            checkForCompletion();
        }

        function checkForCompletion() {
            let allAnswered = true;
            for (let s = 0; s < sections.length; s++) {
                for (let q = 0; q < sections[s].questions.length; q++) {
                    if (!(q in answers[s])) {
                        allAnswered = false;
                        break;
                    }
                }
            }

            if (allAnswered) {
                setTimeout(showVerdict, 400);
            }
        }

        function showVerdict() {
            const verdictDiv = document.getElementById('verdict');

            // Count red flags
            let totalFlags = 0;
            const flagDetails = [];

            sections.forEach((section, sectionIdx) => {
                section.questions.forEach((question, qIdx) => {
                    const answer = answers[sectionIdx][qIdx];
                    if (!answer && question.flagIfNo) {
                        totalFlags++;
                        flagDetails.push({
                            section: section.name,
                            question: question.text,
                            flag: question.flagNote
                        });
                    }
                });
            });

            const ready = totalFlags === 0;

            let verdictHTML = `
                <div class="verdict-icon">${ready ? '🚀' : '⚠️'}</div>
                <div class="verdict-title">${ready ? 'SHIP' : 'NOT READY'}</div>
                <div class="verdict-subtitle">
                    ${ready ?
                        'Karel passes the PM checklist. All risk categories are covered. Safe to ship.' :
                        `${totalFlags} red flag${totalFlags !== 1 ? 's' : ''} prevent launch. Fix these items first.`
                    }
                </div>
            `;

            if (!ready) {
                verdictHTML += '<div class="summary-grid">';
                flagDetails.forEach(detail => {
                    verdictHTML += `
                        <div class="red-flag">
                            <h4>${detail.section}</h4>
                            <p><strong>Issue:</strong> ${detail.question}</p>
                            <div class="fix-item">
                                <strong>→</strong>
                                <span>${detail.flag}</span>
                            </div>
                        </div>
                    `;
                });
                verdictHTML += '</div>';
                verdictHTML += `
                    <div style="margin-top: 32px; padding: 24px; background: #fef2f2; border-radius: 12px; border: 1px solid #fecaca;">
                        <p style="font-size: 15px; color: #991b1b; line-height: 1.8;">
                            <strong>Karel isn't ready</strong> — but he's close. Fix these ${totalFlags} item${totalFlags !== 1 ? 's' : ''} and he will be. Each red flag is actionable. Do not launch until all are resolved.
                        </p>
                    </div>
                `;
            } else {
                verdictHTML += `
                    <div style="margin-top: 32px; padding: 24px; background: #dcfce7; border-radius: 12px; border: 1px solid #86efac;">
                        <p style="font-size: 15px; color: #1f2937; line-height: 1.8;">
                            All 6 checklist sections pass. Scope is locked, evals are complete, safety gates are in place, monitoring is set up, and leadership understands what Karel will and won't do. You can ship with confidence.
                        </p>
                    </div>
                `;
            }

            verdictDiv.classList.add('show', ready ? 'ready' : 'notready');
            verdictDiv.innerHTML = verdictHTML;
        }
    </script>
<script>
  // Send height to parent for auto-resizing
  let lastHeight = 0;
  function sendHeight() {
    const height = document.documentElement.scrollHeight || document.body.scrollHeight;
    if (height !== lastHeight) {
      lastHeight = height;
    window.parent.postMessage({ type: 'resize', height: height + 40 }, '*');
  }
  
  // Send on load
  window.addEventListener('load', sendHeight);
  
  // Send when DOM changes (for dynamic content)
  const observer = new MutationObserver(sendHeight);
  observer.observe(document.body, { childList: true, subtree: true, attributes: true });
  
  // Send periodically to catch any missed changes
  setInterval(sendHeight, 500);
</script></body>
</html>
