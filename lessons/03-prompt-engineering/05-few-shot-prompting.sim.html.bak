<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Example Effect</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: "Plus Jakarta Sans", sans-serif;
      background: #f7f9fb;
      color: #2c3437;
      padding: 40px 20px;
      min-height: 100vh;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
    }

    header {
      margin-bottom: 40px;
    }

    h1 {
      font-size: 32px;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 16px;
      color: #596064;
      font-weight: 400;
    }

    .card {
      background: white;
      border-radius: 24px;
      border: 1px solid rgba(44, 52, 55, 0.12);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      padding: 32px;
      margin-bottom: 24px;
    }

    .toggle-buttons {
      display: flex;
      gap: 12px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .toggle-btn {
      padding: 12px 24px;
      border-radius: 12px;
      border: 2px solid #e5e7eb;
      background: white;
      color: #2c3437;
      cursor: pointer;
      font-family: "Plus Jakarta Sans", sans-serif;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.3s ease;
    }

    .toggle-btn:hover {
      border-color: #4f46e5;
      background: #eef2ff;
    }

    .toggle-btn.active {
      background: linear-gradient(135deg, #4f46e5, #6f68f7);
      color: white;
      border-color: #4f46e5;
    }

    .prompt-display {
      background: #f0f4f8;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 32px;
      font-family: "Courier New", monospace;
      font-size: 13px;
      color: #2c3437;
      line-height: 1.6;
      max-height: 200px;
      overflow-y: auto;
      border: 1px solid rgba(79, 70, 229, 0.2);
    }

    .prompt-label {
      font-size: 12px;
      font-weight: 600;
      color: #596064;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 12px;
    }

    .test-case {
      margin-bottom: 32px;
      padding-bottom: 32px;
      border-bottom: 1px solid #e5e7eb;
    }

    .test-case:last-of-type {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .test-number {
      font-size: 13px;
      font-weight: 700;
      color: #4f46e5;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 12px;
    }

    .customer-message {
      background: #f9fafb;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      border-left: 4px solid #3b82f6;
    }

    .customer-label {
      font-size: 12px;
      font-weight: 600;
      color: #3b82f6;
      text-transform: uppercase;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
    }

    .customer-text {
      font-size: 15px;
      color: #2c3437;
      font-weight: 500;
    }

    .response-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }

    @media (max-width: 768px) {
      .response-grid {
        grid-template-columns: 1fr;
      }
    }

    .response-card {
      border-radius: 12px;
      padding: 16px;
      border: 1px solid #e5e7eb;
      background: #f9fafb;
    }

    .response-card.zero-shot {
      border-left: 4px solid #ef4444;
    }

    .response-card.few-shot {
      border-left: 4px solid #10b981;
      background: #f0fdf4;
    }

    .response-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 12px;
    }

    .zero-shot .response-title {
      color: #ef4444;
    }

    .few-shot .response-title {
      color: #10b981;
    }

    .response-text {
      font-size: 14px;
      line-height: 1.6;
      color: #2c3437;
    }

    .quality-indicator {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-top: 12px;
    }

    .quality-poor {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
    }

    .quality-good {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
    }

    .examples-section {
      background: #eef2ff;
      border-radius: 12px;
      padding: 24px;
      margin-top: 32px;
      border: 1px solid #c7d2fe;
    }

    .examples-title {
      font-weight: 700;
      color: #4f46e5;
      margin-bottom: 16px;
      font-size: 16px;
    }

    .example-item {
      background: white;
      border-radius: 8px;
      padding: 12px;
      margin-bottom: 12px;
      border-left: 3px solid #4f46e5;
      font-size: 13px;
    }

    .example-item:last-child {
      margin-bottom: 0;
    }

    .example-input {
      color: #596064;
      margin-bottom: 8px;
      font-weight: 500;
    }

    .example-arrow {
      color: #4f46e5;
      font-weight: 700;
      margin: 4px 0;
    }

    .example-output {
      color: #2c3437;
      font-weight: 500;
    }

    .insight-box {
      background: #fef3c7;
      border: 1px solid #fcd34d;
      border-radius: 12px;
      padding: 24px;
      margin-top: 32px;
      border-left: 4px solid #f59e0b;
    }

    .insight-title {
      font-weight: 700;
      color: #92400e;
      margin-bottom: 8px;
      font-size: 16px;
    }

    .insight-text {
      color: #b45309;
      font-size: 15px;
      line-height: 1.6;
    }

    .hidden {
      display: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Example Effect</h1>
      <p class="subtitle">Few-shot prompting teaches your agent the pattern. More examples = more consistency.</p>
    </header>

    <div class="card">
      <div class="toggle-buttons">
        <button class="toggle-btn active" onclick="toggleMode('zero')">Zero Examples</button>
        <button class="toggle-btn" onclick="toggleMode('few')">Three Examples</button>
      </div>

      <div class="prompt-label">System Prompt (Examples Section):</div>
      <div class="prompt-display" id="promptDisplay">
        [No examples provided. Karel must figure out the format on his own.]
      </div>

      <div id="zeroShotMode" class="mode-content">
        <div class="examples-section hidden">
          <div class="examples-title">Examples (Zero Examples Mode)</div>
          <p style="font-size: 14px; color: #596064;">No examples are given to Karel. He must invent the response format.</p>
        </div>
      </div>

      <div id="fewShotMode" class="mode-content hidden">
        <div class="examples-section">
          <div class="examples-title">Examples Karel Learns From</div>

          <div class="example-item">
            <div class="example-input">Example 1: Customer said: "There's a weird charge I don't recognize"</div>
            <div class="example-arrow">→</div>
            <div class="example-output">Karel responded: "I'll check your recent transactions. [Tool] I can see a charge for €34.90 at 'CornerShop' on April 19th. Is this the unfamiliar one? I can flag it."</div>
          </div>

          <div class="example-item">
            <div class="example-input">Example 2: Customer said: "This transaction shouldn't be here"</div>
            <div class="example-arrow">→</div>
            <div class="example-output">Karel responded: "Let me look that up for you. [Tool] I see €67.50 charged by 'OnlineRetail' on April 18th. Would you like me to flag this for review?"</div>
          </div>

          <div class="example-item">
            <div class="example-input">Example 3: Customer said: "Is this my charge?"</div>
            <div class="example-arrow">→</div>
            <div class="example-output">Karel responded: "I found the transaction: €45 at 'GasStation' on April 20th. Does this look familiar to you? I can flag it if not."</div>
          </div>
        </div>
      </div>

      <div style="margin-top: 32px;">
        <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 24px;">Test Customer Messages:</h3>

        <div class="test-case">
          <div class="test-number">Message 1</div>
          <div class="customer-message">
            <div class="customer-label">Customer Says:</div>
            <div class="customer-text">"There's a charge I don't recognize from last Tuesday."</div>
          </div>

          <div class="response-grid">
            <div class="response-card zero-shot">
              <div class="response-title">Without Examples</div>
              <div class="response-text">
                Could you provide more details about the charge you don't recognize? I'll need the amount and merchant name to look it up. Once I have that information, I can check your transaction history and determine if this charge is legitimate or potentially fraudulent.
              </div>
              <span class="quality-indicator quality-poor">Generic & Unfocused</span>
            </div>

            <div class="response-card few-shot">
              <div class="response-title">With Examples</div>
              <div class="response-text">
                I'll check your recent transactions right now. [Tool: read_transaction_history] I can see an unfamiliar charge of €34.90 at 'Parkopedia' on Tuesday April 15th. Would you like me to flag this transaction for review?
              </div>
              <span class="quality-indicator quality-good">Specific & Actionable</span>
            </div>
          </div>
        </div>

        <div class="test-case">
          <div class="test-number">Message 2</div>
          <div class="customer-message">
            <div class="customer-label">Customer Says:</div>
            <div class="customer-text">"I don't think I made this purchase."</div>
          </div>

          <div class="response-grid">
            <div class="response-card zero-shot">
              <div class="response-title">Without Examples</div>
              <div class="response-text">
                That's concerning. There are a few options you can explore. You might want to contact your credit card company, check your purchase history, or review your account activity. Let me know if you need further assistance.
              </div>
              <span class="quality-indicator quality-poor">Vague & Indirect</span>
            </div>

            <div class="response-card few-shot">
              <div class="response-title">With Examples</div>
              <div class="response-text">
                Let me find that transaction for you. [Tool: read_transaction_history] I see €89.99 charged to 'ElectroWorld' on April 21st. This doesn't match your purchase? I can flag it immediately for our fraud team to investigate.
              </div>
              <span class="quality-indicator quality-good">Structured & Clear</span>
            </div>
          </div>
        </div>

        <div class="test-case">
          <div class="test-number">Message 3</div>
          <div class="customer-message">
            <div class="customer-label">Customer Says:</div>
            <div class="customer-text">"Something suspicious on my statement."</div>
          </div>

          <div class="response-grid">
            <div class="response-card zero-shot">
              <div class="response-title">Without Examples</div>
              <div class="response-text">
                I understand your concern about something suspicious. To better assist you, could you explain what looks suspicious to you? This will help me determine the best course of action.
              </div>
              <span class="quality-indicator quality-poor">Asks for More Info</span>
            </div>

            <div class="response-card few-shot">
              <div class="response-title">With Examples</div>
              <div class="response-text">
                I'll review your statement right away. [Tool: read_transaction_history] What time period should I check? Once you point me to the suspicious charge, I can flag it and freeze your card if needed.
              </div>
              <span class="quality-indicator quality-good">Takes Initiative</span>
            </div>
          </div>
        </div>
      </div>

      <div class="insight-box">
        <div class="insight-title">The Pattern Recognition Effect</div>
        <div class="insight-text">
          Examples don't just improve ONE response. They set the pattern for ALL responses. When you show Karel three good examples of acknowledge + specific action + next step, he learns that this is the expected format. He applies this pattern to every new customer message, not just the ones you explicitly taught him.
        </div>
      </div>
    </div>
  </div>

  <script>
    function toggleMode(mode) {
      const buttons = document.querySelectorAll('.toggle-btn');
      buttons.forEach(btn => btn.classList.remove('active'));
      event.target.classList.add('active');

      const zeroMode = document.getElementById('zeroShotMode');
      const fewMode = document.getElementById('fewShotMode');

      if (mode === 'zero') {
        zeroMode.classList.remove('hidden');
        fewMode.classList.add('hidden');
        document.getElementById('promptDisplay').textContent = '[No examples provided. Karel must figure out the format on his own.]';
      } else {
        zeroMode.classList.add('hidden');
        fewMode.classList.remove('hidden');
        document.getElementById('promptDisplay').textContent = 'Example 1: Customer said "weird charge" → Karel: "I\'ll check your transactions. [Tool] I can see €34.90 at \'CornerShop\'. Is this the one? I can flag it."\n\nExample 2: Customer said "shouldn\'t be here" → Karel: "Let me look it up. [Tool] I see €67.50 at \'OnlineRetail\'. Flag it?"\n\nExample 3: Customer said "is this mine?" → Karel: "Found it: €45 at \'GasStation\'. Looks unfamiliar? I can flag it."';
      }
    }
  </script>
<script>
  // Send height to parent for auto-resizing
  let lastHeight = 0;
  function sendHeight() {
    const height = document.documentElement.scrollHeight || document.body.scrollHeight;
    if (height !== lastHeight) {
      lastHeight = height;
    window.parent.postMessage({ type: 'resize', height: height + 40 }, '*');
  }
  
  // Send on load
  window.addEventListener('load', sendHeight);
  
  // Send when DOM changes (for dynamic content)
  const observer = new MutationObserver(sendHeight);
  observer.observe(document.body, { childList: true, subtree: true, attributes: true });
  
  // Send periodically to catch any missed changes
  setInterval(sendHeight, 500);
</script></body>
</html>
